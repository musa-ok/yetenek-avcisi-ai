import 'dart:io';
import 'dart:ui' as ui;
import 'package:flutter/material.dart';
import 'package:flutter/rendering.dart';
import 'package:flutter/services.dart';
import 'package:share_plus/share_plus.dart';
import 'package:fl_chart/fl_chart.dart';
import 'package:flutter_animate/flutter_animate.dart';
import 'package:percent_indicator/percent_indicator.dart';
import '../app_theme.dart';
import '../services/multi_upload_service.dart';

/// ==========================================
/// PLAYER STATS SCREEN
/// Radar Chart + Progress Bars + FIFA Card Share
/// ==========================================

class PlayerStatsScreen extends StatefulWidget {
  final MultiVideoPlayer player;
  final VoidCallback? onAnalysisComplete;

  const PlayerStatsScreen({
    super.key,
    required this.player,
    this.onAnalysisComplete,
  });

  @override
  State<PlayerStatsScreen> createState() => _PlayerStatsScreenState();
}

class _PlayerStatsScreenState extends State<PlayerStatsScreen> {
  // Ekran görüntüsü almak için sihirli anahtarımız
  final GlobalKey _globalKey = GlobalKey();
  bool _isSharing = false;

  Future<void> _shareFifaCard() async {
    if (_isSharing) return;
    setState(() => _isSharing = true);

    try {
      // 1. RepaintBoundary'den yüksek kaliteli resmi çek
      RenderRepaintBoundary boundary = _globalKey.currentContext!.findRenderObject() as RenderRepaintBoundary;
      ui.Image image = await boundary.toImage(pixelRatio: 3.0);
      ByteData? byteData = await image.toByteData(format: ui.ImageByteFormat.png);

      if (byteData != null) {
        final Uint8List pngBytes = byteData.buffer.asUint8List();

        // 2. Telefonun önbelleğine geçici olarak kaydet
        final directory = await Directory.systemTemp.createTemp();
        final imagePath = await File('${directory.path}/yetenek_avcisi_karti.png').create();
        await imagePath.writeAsBytes(pngBytes);

        // 3. WhatsApp, Instagram vb. için paylaşım menüsünü aç
        await Share.shareXFiles(
          [XFile(imagePath.path)],
          text: '🔥 ${widget.player.name} - AI Scout Raporu!\nSen de Yetenek Avcısı\'nı indir ve kendi kartını oluştur! ⚽',
        );
      }
    } catch (e) {
      debugPrint('Paylaşım hatası: $e');
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Kart paylaşılamadı: $e'), backgroundColor: Colors.red),
        );
      }
    } finally {
      if (mounted) {
        setState(() => _isSharing = false);
      }
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: AppColors.scaffoldBackground,
      extendBodyBehindAppBar: true,
      appBar: AppBar(
        leading: IconButton(
          icon: Icon(Icons.arrow_back, color: AppColors.textPrimary),
          onPressed: () {
            widget.onAnalysisComplete?.call();
            Navigator.of(context).pop();
          },
        ),
        title: Text(
          'Yetenek Analizi',
          style: Theme.of(context).textTheme.headlineSmall?.copyWith(
            color: AppColors.textPrimary,
          ),
        ),
        backgroundColor: Colors.transparent,
        elevation: 0,
        actions: [
          _isSharing
              ? Padding(
                  padding: const EdgeInsets.symmetric(horizontal: 16.0),
                  child: Center(child: SizedBox(width: 20, height: 20, child: CircularProgressIndicator(strokeWidth: 2, color: AppColors.accentGreen))),
                )
              : IconButton(
                  icon: Icon(Icons.share, color: AppColors.accentGreen),
                  onPressed: _shareFifaCard, // Paylaşma fonksiyonunu bağladık
                ),
        ],
      ),
      body: SafeArea(
        child: SingleChildScrollView(
          padding: EdgeInsets.all(20),
          child: Column(
            children: [
              // SADECE BURAYI EKRAN GÖRÜNTÜSÜ ALIYORUZ (FIFA KARTI BÖLÜMÜ)
              RepaintBoundary(
                key: _globalKey,
                child: _buildHeaderCard(context),
              ),
              
              SizedBox(height: 24),
              _buildRadarChart(context),
              SizedBox(height: 32),
              _buildVideoAnalysis(context),
              SizedBox(height: 32),
              
              if (widget.player.aiSummaryReport != null)
                _buildAIReport(context),
              
              SizedBox(height: 32),
              _buildStrengthsAndImprovements(context),
            ],
          ),
        ),
      ),
    );
  }

  Widget _buildHeaderCard(BuildContext context) {
    return GlassmorphismContainer(
      padding: EdgeInsets.all(24),
      // Kart arka planını skora göre renklendiriyoruz
      backgroundColor: _getCardColor(widget.player.overallRating).withValues(alpha: 0.15),
      borderColor: _getCardColor(widget.player.overallRating).withValues(alpha: 0.3),
      child: Column(
        children: [
          Row(
            children: [
              Container(
                padding: EdgeInsets.symmetric(horizontal: 14, vertical: 8),
                decoration: BoxDecoration(
                  color: AppColors.glassWhite,
                  borderRadius: BorderRadius.circular(20),
                ),
                child: Text(
                  widget.player.position,
                  style: TextStyle(
                    color: AppColors.accentGreen,
                    fontWeight: FontWeight.bold,
                    fontSize: 14,
                  ),
                ),
              ),
              Spacer(),
              Container(
                padding: EdgeInsets.symmetric(horizontal: 14, vertical: 8),
                decoration: BoxDecoration(
                  color: AppColors.glassWhite,
                  borderRadius: BorderRadius.circular(20),
                ),
                child: Text(
                  '${widget.player.age} Yaş',
                  style: TextStyle(
                    color: AppColors.textSecondary,
                    fontSize: 14,
                  ),
                ),
              ),
            ],
          ),
          SizedBox(height: 24),
          Text(
            widget.player.name.toUpperCase(),
            style: TextStyle(
              fontSize: 28,
              fontWeight: FontWeight.w900,
              fontStyle: FontStyle.italic,
              letterSpacing: 1.2,
              color: AppColors.textPrimary,
            ),
          ),
          SizedBox(height: 24),
          AnimatedScore(score: widget.player.overallRating, size: 120),
        ],
      ),
    ).animate().fadeIn(duration: 500.ms);
  }

  Color _getCardColor(int score) {
    if (score >= 80) return AppColors.accentGreen;
    if (score >= 60) return AppColors.accentBlue;
    if (score >= 40) return AppColors.accentYellow;
    return AppColors.accentOrange;
  }

  Widget _buildRadarChart(BuildContext context) {
    if (widget.player.skillScores.isEmpty) return SizedBox.shrink();

    final skills = widget.player.skillScores.entries.toList();
    
    return GlassmorphismContainer(
      padding: EdgeInsets.all(20),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Text(
            'Yetenek Haritası',
            style: Theme.of(context).textTheme.titleMedium?.copyWith(
              fontWeight: FontWeight.w600,
            ),
          ),
          SizedBox(height: 20),
          AspectRatio(
            aspectRatio: 1,
            child: RadarChart(
              RadarChartData(
                dataSets: [
                  RadarDataSet(
                    dataEntries: skills.map((skill) {
                      return RadarEntry(value: skill.value.toDouble());
                    }).toList(),
                    fillColor: AppColors.accentGreen.withValues(alpha: 0.2),
                    borderColor: AppColors.accentGreen,
                    entryRadius: 4,
                    borderWidth: 2.5,
                  ),
                ],
                radarBackgroundColor: Colors.transparent,
                borderData: FlBorderData(show: false),
                radarBorderData: BorderSide(color: AppColors.glassBorder, width: 1),
                gridBorderData: BorderSide(color: AppColors.glassBorder, width: 0.5),
                tickBorderData: BorderSide(color: AppColors.glassBorder, width: 0.5),
                ticksTextStyle: TextStyle(color: Colors.transparent, fontSize: 10),
                titleTextStyle: TextStyle(color: AppColors.textSecondary, fontSize: 11, fontWeight: FontWeight.w500),
                getTitle: (index, angle) {
                  if (index >= skills.length) return RadarChartTitle(text: '');
                  return RadarChartTitle(
                    text: skills[index].key.toString().replaceAll('_', ' ').toUpperCase(),
                    angle: angle,
                  );
                },
                titlePositionPercentageOffset: 0.12,
                tickCount: 5,
              ),
            ),
          ),
        ],
      ),
    ).animate().fadeIn(delay: 200.ms, duration: 500.ms);
  }

  Widget _buildVideoAnalysis(BuildContext context) {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        Text(
          'Video Analizleri',
          style: Theme.of(context).textTheme.titleMedium?.copyWith(
            fontWeight: FontWeight.w600,
          ),
        ),
        SizedBox(height: 16),
        ...widget.player.videos.where((v) => v.isUploaded).map((video) {
          return _buildVideoProgressCard(context, video);
        }).toList(),
      ],
    );
  }

  Widget _buildVideoProgressCard(BuildContext context, VideoInfo video) {
    final score = video.rating ?? 0;
    final progress = score / 100;
    
    Color progressColor = _getCardColor(score);

    return GlassmorphismContainer(
      margin: EdgeInsets.only(bottom: 12),
      padding: EdgeInsets.all(20),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              Container(
                width: 40,
                height: 40,
                decoration: BoxDecoration(
                  gradient: LinearGradient(
                    colors: [
                      progressColor.withValues(alpha: 0.3),
                      progressColor.withValues(alpha: 0.1),
                    ],
                  ),
                  borderRadius: BorderRadius.circular(12),
                ),
                child: Center(
                  child: Text(
                    '${video.slot}',
                    style: TextStyle(
                      color: progressColor,
                      fontWeight: FontWeight.bold,
                    ),
                  ),
                ),
              ),
              SizedBox(width: 12),
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(
                      video.skill ?? 'Bilinmeyen Yetenek',
                      style: Theme.of(context).textTheme.titleSmall?.copyWith(
                        fontWeight: FontWeight.w600,
                      ),
                    ),
                    SizedBox(height: 4),
                    LinearPercentIndicator(
                      lineHeight: 8,
                      percent: progress,
                      backgroundColor: AppColors.glassWhite,
                      progressColor: progressColor,
                      barRadius: Radius.circular(4),
                      animation: true,
                      animationDuration: 1000,
                    ),
                  ],
                ),
              ),
              SizedBox(width: 12),
              Text(
                '$score',
                style: TextStyle(
                  fontSize: 20,
                  fontWeight: FontWeight.bold,
                  color: progressColor,
                ),
              ),
            ],
          ),
        ],
      ),
    ).animate().fadeIn(delay: (video.slot * 100).ms);
  }

  Widget _buildAIReport(BuildContext context) {
    return GlassmorphismContainer(
      padding: EdgeInsets.all(20),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              Icon(Icons.psychology, color: AppColors.accentPurple),
              SizedBox(width: 8),
              Text(
                'AI Scout Raporu',
                style: Theme.of(context).textTheme.titleMedium?.copyWith(
                  fontWeight: FontWeight.w600,
                  color: AppColors.accentPurple,
                ),
              ),
            ],
          ),
          SizedBox(height: 16),
          _buildFormattedAIReport(context),
        ],
      ),
    ).animate().fadeIn(delay: 400.ms);
  }

  Widget _buildFormattedAIReport(BuildContext context) {
    final report = widget.player.aiSummaryReport ?? '';
    
    final bool needsReanalysis = report.isEmpty || 
        report.toLowerCase().contains('the player') ||
        report.toLowerCase().contains('video provides');
    
    if (needsReanalysis) {
      return Container(
        padding: EdgeInsets.all(16),
        decoration: BoxDecoration(
          color: AppColors.warning.withValues(alpha: 0.1),
          borderRadius: BorderRadius.circular(12),
          border: Border.all(color: AppColors.warning.withValues(alpha: 0.3)),
        ),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Row(
              children: [
                Icon(Icons.info_outline, color: AppColors.warning, size: 20),
                SizedBox(width: 8),
                Text(
                  'Yeni Analiz Gerekli',
                  style: TextStyle(color: AppColors.warning, fontWeight: FontWeight.w600),
                ),
              ],
            ),
            SizedBox(height: 8),
            Text(
              'Daha iyi bir analiz deneyimi için lütfen videoları yeniden yükleyin.',
              style: Theme.of(context).textTheme.bodySmall,
            ),
          ],
        ),
      );
    }
    
    return Container(
      padding: EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: AppColors.glassWhite,
        borderRadius: BorderRadius.circular(12),
      ),
      child: Text(
        report,
        style: Theme.of(context).textTheme.bodyMedium?.copyWith(
          height: 1.7,
          fontSize: 14,
        ),
      ),
    );
  }

  Widget _buildStrengthsAndImprovements(BuildContext context) {
    return Row(
      children: [
        Expanded(
          child: GestureDetector(
            onTap: () => _showStrengthsModal(context),
            child: GlassmorphismContainer(
              padding: EdgeInsets.all(16),
              backgroundColor: AppColors.success.withValues(alpha: 0.1),
              borderColor: AppColors.success.withValues(alpha: 0.3),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Row(
                    children: [
                      Icon(Icons.trending_up, color: AppColors.success, size: 20),
                      SizedBox(width: 8),
                      Text('Güçlü Yönler', style: TextStyle(color: AppColors.success, fontWeight: FontWeight.w600, fontSize: 14)),
                      Spacer(),
                      Icon(Icons.chevron_right, color: AppColors.success, size: 16),
                    ],
                  ),
                  SizedBox(height: 12),
                  ...widget.player.aiStrengths.take(2).map((strength) {
                    return Padding(
                      padding: EdgeInsets.only(bottom: 8),
                      child: Row(
                        children: [
                          Icon(Icons.check_circle, color: AppColors.success, size: 16),
                          SizedBox(width: 8),
                          Expanded(
                            child: Text(
                              strength,
                              style: TextStyle(color: AppColors.textSecondary, fontSize: 12),
                              maxLines: 1,
                              overflow: TextOverflow.ellipsis,
                            ),
                          ),
                        ],
                      ),
                    );
                  }).toList(),
                ],
              ),
            ),
          ),
        ),
        
        SizedBox(width: 12),
        
        Expanded(
          child: GestureDetector(
            onTap: () => _showImprovementsModal(context),
            child: GlassmorphismContainer(
              padding: EdgeInsets.all(16),
              backgroundColor: AppColors.accentOrange.withValues(alpha: 0.1),
              borderColor: AppColors.accentOrange.withValues(alpha: 0.3),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Row(
                    children: [
                      Icon(Icons.trending_flat, color: AppColors.accentOrange, size: 20),
                      SizedBox(width: 8),
                      Text('Gelişim', style: TextStyle(color: AppColors.accentOrange, fontWeight: FontWeight.w600, fontSize: 14)),
                      Spacer(),
                      Icon(Icons.chevron_right, color: AppColors.accentOrange, size: 16),
                    ],
                  ),
                  SizedBox(height: 12),
                  ...widget.player.aiImprovements.take(2).map((improvement) {
                    return Padding(
                      padding: EdgeInsets.only(bottom: 8),
                      child: Row(
                        children: [
                          Icon(Icons.arrow_forward, color: AppColors.accentOrange, size: 16),
                          SizedBox(width: 8),
                          Expanded(
                            child: Text(
                              improvement,
                              style: TextStyle(color: AppColors.textSecondary, fontSize: 12),
                              maxLines: 1,
                              overflow: TextOverflow.ellipsis,
                            ),
                          ),
                        ],
                      ),
                    );
                  }).toList(),
                ],
              ),
            ),
          ),
        ),
      ],
    ).animate().fadeIn(delay: 500.ms);
  }

  void _showStrengthsModal(BuildContext context) {
    showModalBottomSheet(
      context: context,
      backgroundColor: Colors.transparent,
      isScrollControlled: true,
      builder: (context) => Container(
        decoration: BoxDecoration(color: AppColors.surface, borderRadius: BorderRadius.vertical(top: Radius.circular(20))),
        padding: EdgeInsets.all(24),
        child: Column(
          mainAxisSize: MainAxisSize.min,
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Row(
              children: [
                Icon(Icons.trending_up, color: AppColors.success),
                SizedBox(width: 8),
                Text('Güçlü Yönler', style: Theme.of(context).textTheme.titleLarge?.copyWith(color: AppColors.success, fontWeight: FontWeight.bold)),
                Spacer(),
                IconButton(icon: Icon(Icons.close), onPressed: () => Navigator.pop(context)),
              ],
            ),
            SizedBox(height: 16),
            ...widget.player.aiStrengths.map((strength) => Padding(
              padding: EdgeInsets.only(bottom: 12),
              child: Row(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Icon(Icons.check_circle, color: AppColors.success, size: 20),
                  SizedBox(width: 12),
                  Expanded(child: Text(strength, style: Theme.of(context).textTheme.bodyMedium?.copyWith(height: 1.5))),
                ],
              ),
            )).toList(),
            SizedBox(height: 24),
          ],
        ),
      ),
    );
  }

  void _showImprovementsModal(BuildContext context) {
    showModalBottomSheet(
      context: context,
      backgroundColor: Colors.transparent,
      isScrollControlled: true,
      builder: (context) => Container(
        decoration: BoxDecoration(color: AppColors.surface, borderRadius: BorderRadius.vertical(top: Radius.circular(20))),
        padding: EdgeInsets.all(24),
        child: Column(
          mainAxisSize: MainAxisSize.min,
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Row(
              children: [
                Icon(Icons.trending_flat, color: AppColors.accentOrange),
                SizedBox(width: 8),
                Text('Gelişim Alanları', style: Theme.of(context).textTheme.titleLarge?.copyWith(color: AppColors.accentOrange, fontWeight: FontWeight.bold)),
                Spacer(),
                IconButton(icon: Icon(Icons.close), onPressed: () => Navigator.pop(context)),
              ],
            ),
            SizedBox(height: 16),
            ...widget.player.aiImprovements.map((improvement) => Padding(
              padding: EdgeInsets.only(bottom: 12),
              child: Row(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Icon(Icons.arrow_forward, color: AppColors.accentOrange, size: 20),
                  SizedBox(width: 12),
                  Expanded(child: Text(improvement, style: Theme.of(context).textTheme.bodyMedium?.copyWith(height: 1.5))),
                ],
              ),
            )).toList(),
            SizedBox(height: 24),
          ],
        ),
      ),
    );
  }
}